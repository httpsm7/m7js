}

# ─── HTTP Fetcher ─────────────────────────────────────────────────────────────
def fetch_url(url, timeout=15, follow_js=True):
    """
    Fetch a URL. Returns (status_code, content, error, final_url, js_urls)
    js_urls = list of discovered .js file URLs from HTML pages
    """
    headers = {
        "User-Agent": "Mozilla/5.0 (X11; Linux x86_64; rv:109.0) Gecko/20100101 Firefox/115.0",
        "Accept": "*/*",
        "Accept-Language": "en-US,en;q=0.9",
        "Connection": "keep-alive",
    }
    ctx = ssl.create_default_context()
    ctx.check_hostname = False
    ctx.verify_mode = ssl.CERT_NONE

    try:
        req = urllib.request.Request(url, headers=headers)
        with urllib.request.urlopen(req, timeout=timeout, context=ctx) as resp:
            status = resp.status
            final_url = resp.url
            content_type = resp.headers.get("Content-Type", "")
            raw = resp.read()
            try:
                content = raw.decode("utf-8", errors="replace")
            except Exception:
                content = raw.decode("latin-1", errors="replace")

            js_urls = []
            # Extract embedded .js URLs from HTML pages
            if "html" in content_type and follow_js:
                js_urls = extract_js_urls(content, final_url)

            return status, content, None, final_url, js_urls

    except urllib.error.HTTPError as e:
        return e.code, "", f"HTTP {e.code} {e.reason}", url, []
    except urllib.error.URLError as e:
        return 0, "", f"URL Error: {e.reason}", url, []
    except socket.timeout:
        return 0, "", "Connection timed out", url, []
    except Exception as e:
        return 0, "", f"Exception: {str(e)}", url, []

def extract_js_urls(html_content, base_url):
    """Extract all .js file URLs from an HTML page"""
    pattern = r'(?:src|href)\s*=\s*["\']([^"\']+\.js(?:\?[^"\']*)?)["\']'
    matches = re.findall(pattern, html_content, re.IGNORECASE)
    parsed_base = urllib.parse.urlparse(base_url)
    js_urls = []
    for match in matches:
        if match.startswith("http://") or match.startswith("https://"):
            js_urls.append(match)
        elif match.startswith("//"):
            js_urls.append(f"{parsed_base.scheme}:{match}")
        elif match.startswith("/"):
            js_urls.append(f"{parsed_base.scheme}://{parsed_base.netloc}{match}")
        else:
            base_path = parsed_base.path.rsplit("/", 1)[0]
            js_urls.append(f"{parsed_base.scheme}://{parsed_base.netloc}{base_path}/{match}")
    return list(set(js_urls))

# ─── Pattern Scanner ──────────────────────────────────────────────────────────
def scan_content(content, url):
    """Scan JS content for sensitive patterns. Returns list of findings."""
    findings = []
    lines = content.splitlines()

    for pattern_name, pattern in PATTERNS.items():
        try:
            for i, line in enumerate(lines, 1):
                for match in re.finditer(pattern, line):
                    value = match.group(0)
                    # Skip obviously false positives
                    if len(value) < 6:
                        continue
                    if pattern_name in ["IPv4 Address"] and any(
                        v in value for v in ["255.255", "127.0.0", "0.0.0.0"]
                    ):
                        continue
                    severity = get_severity(pattern_name)
                    findings.append({
                        "url": url,
                        "pattern": pattern_name,
                        "severity": severity,
                        "line": i,
                        "value": value[:200],  # truncate very long values
                        "context": line.strip()[:300],
                    })
        except re.error:
            continue

    # Deduplicate: same pattern + same value
    seen = set()
    unique = []
    for f in findings:
        key = (f["pattern"], f["value"])
        if key not in seen:
            seen.add(key)
            unique.append(f)

    return unique

# ─── Output / Reporting ───────────────────────────────────────────────────────
def print_finding(f):
    sev = f["severity"]
    color = SEV_COLORS.get(sev, Fore.WHITE)
    print(f"  {color}[{sev}]{Style.RESET_ALL} {Fore.GREEN}{f['pattern']}{Style.RESET_ALL}")
    print(f"    {Fore.YELLOW}Line {f['line']}:{Style.RESET_ALL} {f['context'][:120]}")
    print(f"    {Fore.MAGENTA}Value:{Style.RESET_ALL} {f['value'][:100]}")

def save_results(all_results, output_file):
    lines = []
    lines.append("=" * 70)
    lines.append(f"  M7JS - JavaScript Secrets Hunter")
    lines.append(f"  Scan Date : {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    lines.append(f"  Tool      : github.com/m7js")
    lines.append("=" * 70)
    lines.append("")

    total_findings = 0
    for result in all_results:
        lines.append(f"URL: {result['url']}")
        if result.get("error"):
            lines.append(f"  [ERROR] {result['error']}")
        elif result.get("is_html"):
            lines.append(f"  [INFO] HTML page — extracted {len(result.get('js_urls',[]))} JS file(s)")
        else:
            lines.append(f"  Status: {result.get('status', '?')} | Content-Length: {result.get('length', 0)} chars")
            findings = result.get("findings", [])
            if findings:
                lines.append(f"  Findings: {len(findings)}")
                for f in findings:
                    total_findings += 1
                    lines.append(f"")
                    lines.append(f"  [{f['severity']}] {f['pattern']}")
                    lines.append(f"    Line    : {f['line']}")
                    lines.append(f"    Value   : {f['value']}")
                    lines.append(f"    Context : {f['context'][:200]}")
            else:
                lines.append("  No sensitive data found.")
        lines.append("-" * 70)

    lines.append("")
    lines.append(f"Total Findings: {total_findings}")

    with open(output_file, "w", encoding="utf-8") as fh:
        fh.write("\n".join(lines))

    return total_findings

# ─── Core Scan Logic ──────────────────────────────────────────────────────────
def scan_url(url, depth=0, max_depth=1, visited=None):
    """
    Scan a single URL. If it's HTML, extract & scan embedded JS files too.
    Returns list of result dicts.
    """
    if visited is None:
        visited = set()
    if url in visited:
        return []
    visited.add(url)

    results = []
    print(f"\n{Fore.CYAN}[*]{Style.RESET_ALL} Scanning: {Fore.WHITE}{url}{Style.RESET_ALL}")

    status, content, error, final_url, js_urls = fetch_url(url)

    if error:
        print(f"  {Fore.RED}[ERROR]{Style.RESET_ALL} {error}")
        results.append({"url": url, "error": error, "status": status})
        return results

    # Detect if it's HTML
    is_html = bool(re.search(r'<html|<!DOCTYPE', content[:500], re.IGNORECASE))

    if is_html:
        print(f"  {Fore.YELLOW}[HTML]{Style.RESET_ALL} Page detected — found {len(js_urls)} JS file(s)")
        results.append({"url": url, "status": status, "is_html": True, "js_urls": js_urls})
        if depth < max_depth:
            for js_url in js_urls:
                if js_url not in visited:
                    sub = scan_url(js_url, depth=depth+1, max_depth=max_depth, visited=visited)
                    results.extend(sub)
    else:
        # It's likely a JS file or raw content
        print(f"  {Fore.GREEN}[JS]{Style.RESET_ALL} Content: {len(content)} chars — scanning...")
        findings = scan_content(content, final_url)

        sev_count = {"CRITICAL": 0, "HIGH": 0, "MEDIUM": 0, "LOW": 0, "INFO": 0}
        for f in findings:
            sev_count[f["severity"]] = sev_count.get(f["severity"], 0) + 1
            print_finding(f)

        summary_parts = []
        for sev in ["CRITICAL", "HIGH", "MEDIUM", "LOW", "INFO"]:
            if sev_count[sev] > 0:
                summary_parts.append(f"{SEV_COLORS[sev]}{sev}:{sev_count[sev]}{Style.RESET_ALL}")
        if summary_parts:
            print(f"  {Fore.WHITE}[SUMMARY]{Style.RESET_ALL} " + " | ".join(summary_parts))
        else:
            print(f"  {Fore.GREEN}[CLEAN]{Style.RESET_ALL} No sensitive data found.")

        results.append({
            "url": final_url,
            "status": status,
            "length": len(content),
            "findings": findings,
        })

    return results

def scan_file(filepath):
    """Read URLs from a file and scan each one."""
    if not os.path.isfile(filepath):
        print(f"{Fore.RED}[ERROR]{Style.RESET_ALL} File not found: {filepath}")
        sys.exit(1)

    with open(filepath, "r", encoding="utf-8") as fh:
        urls = [line.strip() for line in fh if line.strip() and not line.startswith("#")]

    print(f"{Fore.CYAN}[*]{Style.RESET_ALL} Loaded {len(urls)} URL(s) from {filepath}")
    return urls

# ─── Main ─────────────────────────────────────────────────────────────────────
def main():
    print(BANNER)

    parser = argparse.ArgumentParser(
        prog="m7js",
        description="JavaScript Secrets Hunter — find sensitive data in JS files",
        formatter_class=argparse.RawTextHelpFormatter
    )
    parser.add_argument("-u", "--url", metavar="URL",
                        help="Single URL to scan (JS file or HTML page)")
    parser.add_argument("-f", "--file", metavar="FILE",
                        help="File containing list of URLs (one per line)")
    parser.add_argument("-o", "--output", metavar="FILE",
                        default=OUTPUT_FILE,
                        help=f"Output file (default: {OUTPUT_FILE})")
    parser.add_argument("-t", "--threads", type=int, default=5,
                        help="Number of parallel threads for file mode (default: 5)")
    parser.add_argument("--depth", type=int, default=1,
                        help="Crawl depth for HTML pages (default: 1)")
    parser.add_argument("--no-color", action="store_true",
                        help="Disable colored output")
    parser.add_argument("-v", "--version", action="version", version=f"m7js v{VERSION}")

    args = parser.parse_args()

    if args.no_color:
        init(strip=True)

    if not args.url and not args.file:
        parser.print_help()
        sys.exit(0)

    urls = []
    if args.url:
        urls = [args.url]
    elif args.file:
        urls = scan_file(args.file)

    print(f"\n{Fore.CYAN}[*]{Style.RESET_ALL} Output file: {Fore.YELLOW}{args.output}{Style.RESET_ALL}")
    print(f"{Fore.CYAN}[*]{Style.RESET_ALL} Scan started at {datetime.now().strftime('%H:%M:%S')}\n")
    print("─" * 60)

    start_time = time.time()
    all_results = []
    visited = set()

    if len(urls) == 1 or args.threads == 1:
        for url in urls:
            results = scan_url(url, max_depth=args.depth, visited=visited)
            all_results.extend(results)
            time.sleep(0.3)
    else:
        # Multi-threaded for file mode
        with ThreadPoolExecutor(max_workers=args.threads) as executor:
            futures = {executor.submit(scan_url, url, 0, args.depth, set()): url for url in urls}
            for future in as_completed(futures):
                try:
                    results = future.result()
                    all_results.extend(results)
                except Exception as e:
                    url = futures[future]
                    print(f"{Fore.RED}[ERROR]{Style.RESET_ALL} Thread failed for {url}: {e}")

    elapsed = time.time() - start_time
    print("\n" + "─" * 60)

    total = save_results(all_results, args.output)
    js_scanned = sum(1 for r in all_results if not r.get("is_html") and not r.get("error"))
    errors = sum(1 for r in all_results if r.get("error"))

    print(f"\n{Fore.GREEN}[✓] Scan Complete{Style.RESET_ALL}")
    print(f"    URLs processed : {len(urls)}")
    print(f"    JS files scanned: {js_scanned}")
    print(f"    Errors          : {Fore.RED if errors else ''}{errors}{Style.RESET_ALL}")
    print(f"    Total Findings  : {Fore.RED if total else Fore.GREEN}{total}{Style.RESET_ALL}")
    print(f"    Time elapsed    : {elapsed:.2f}s")
    print(f"    Results saved   : {Fore.YELLOW}{args.output}{Style.RESET_ALL}\n")

if __name__ == "__main__":
    main()
